[color]
  ui = auto
[user]
  name = FranciscoJRSantos
  email = franciscojrsantos1997@gmail.com
  signingkey = 21D0EA9F95EF54CB
[core]
  editor = nvim
[color]
  ui = true
[color "branch"]
  current = yellow reverse
  local = yellow
  remote = green

[color "diff"]
  meta = yellow bold
  frag = magenta bold
  old = red bold
  new = green bold

[color "status"]
  added = yellow
  changed = green
  untracked = red

[alias]
  ci = commit
  unstage = reset HEAD --
  st = status
  co = checkout
